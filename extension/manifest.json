{
  "manifest_version": 2,
  "name": "Readwise Full Content",
  "version": "1.2.1",
  "description": "Automatically enriches Readwise Reader documents with full page content from paywalled sites you're subscribed to",

  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs",
    "https://readwise.io/*",
    "*://*/*"
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Save to Readwise Reader"
  },

  "background": {
    "scripts": ["readwise.js", "background.js"],
    "persistent": true
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "readwise-full-content@byk.im",
      "strict_min_version": "113.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "113.0"
    }
  }
}
